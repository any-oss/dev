# Policy Gateway runtime defaults
PGW_HOST=0.0.0.0
PGW_PORT=8000
PGW_DATA_DIR=var/policy-gateway
PGW_UPSTREAM_URL=http://llama:8080/completion
PGW_RATE_LIMIT_RPM=120
PGW_MAX_BODY_BYTES=1048576
PGW_METRICS_SCRAPE_GATE_MS=200
PGW_FLUSH_INTERVAL_S=25
PGW_INTEGRITY_INTERVAL_S=60
PGW_BACKUP_INTERVAL_S=900
PGW_MEMORY_FLOOR_KB=950000
PGW_QPS_HIGH=320
PGW_QPS_LOW=280
PGW_P95_LATENCY_MS=1850
PGW_ERROR_RATE_HIGH=0.045
PGW_AUDIT_MAX_BYTES=10485760
# Optional: load config/*.json layer bundle instead of individual env defaults
# PGW_CONFIG_DIR=config
